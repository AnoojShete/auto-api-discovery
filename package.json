{
  "name": "auto-api-discovery",
  "version": "2.0.0",
  "description": "Hybrid API discovery — intercept, infer, and reconstruct OpenAPI specs",
  "main": "dist/index.js",
  "bin": {
    "apigen": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/index.ts",
    "test": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "postinstall": "playwright install chromium"
  },
  "keywords": [
    "api",
    "openapi",
    "cli",
    "playwright",
    "automation"
  ],
  "author": "Anooj Shete",
  "license": "MIT",
  "dependencies": {
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "better-sqlite3": "^12.8.0",
    "chalk": "^4.1.2",
    "commander": "^12.0.0",
    "openapi3-ts": "^4.5.0",
    "playwright": "^1.42.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.9",
    "@types/node": "^20.11.24",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}