{
  "name": "auto-api-discovery",
  "version": "2.0.0",
  "description": "Hybrid API discovery — intercept, infer, and reconstruct OpenAPI specs",
  "main": "dist/index.js",
  "bin": {
    "apigen": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/index.ts",
    "test": "vitest run",
    "test:types": "tsc --noEmit",
    "fixture:rest": "node test/fixtures/rest/server.js",
    "fixture:graphql": "node test/fixtures/graphql/server.js",
    "fixture:websocket": "node test/fixtures/websocket/server.js",
    "fixture:auth": "node test/fixtures/auth/server.js",
    "prepublishOnly": "npm run build",
    "postinstall": "playwright install chromium"
  },
  "keywords": [
    "api",
    "openapi",
    "cli",
    "playwright",
    "automation"
  ],
  "author": "Anooj Shete",
  "license": "MIT",
  "dependencies": {
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "better-sqlite3": "^12.8.0",
    "chalk": "^4.1.2",
    "commander": "^12.0.0",
    "openapi3-ts": "^4.5.0",
    "playwright": "^1.42.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.9",
    "@types/node": "^20.11.24",
    "@types/express": "^4.17.21",
    "@types/ws": "^8.5.10",
    "express": "^4.19.2",
    "vitest": "^1.6.0",
    "ws": "^8.17.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}